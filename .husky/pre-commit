#!/usr/bin/env sh
set -e

echo "→ eslint (staged files)"
STAGED=$(git diff --cached --name-only --diff-filter=d -- '*.ts' '*.tsx')
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs ./node_modules/.bin/eslint --max-warnings=0
fi

echo "→ type-check"
./node_modules/.bin/tsc --noEmit

echo "→ tests"
./node_modules/.bin/jest --passWithNoTests --bail --ci
